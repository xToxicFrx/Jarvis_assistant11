# ============================================================
# WICHTIG: Diese Werte trägst du NICHT in eine Datei ein!
# Sie kommen bei Vercel unter "Settings -> Environment Variables".
# Diese Datei zeigt nur, WELCHE Variablen der Server braucht.
# So gelangen deine Keys nie auf GitHub und nie in den Browser.
# ============================================================

# Dein OpenAI-Key (für Gehirn + Whisper). Von platform.openai.com
OPENAI_API_KEY=sk-...

# Dein ElevenLabs-Key (für die Stimme). Von elevenlabs.io
ELEVENLABS_API_KEY=...

# Welche ElevenLabs-Stimme JARVIS benutzt
ELEVENLABS_VOICE_ID=MMwckqU477oQxnAk1SgA

# DEIN selbst ausgedachtes Zugangspasswort (damit nur DU JARVIS nutzen kannst)
APP_PASSWORD=dein-geheimes-passwort

# Optional: anderes Modell. Standard ist gpt-4o-mini (günstig).
LLM_MODEL=gpt-4o-mini
